# ============================================================
# 城脉 LU · 环境变量（复制为 .env 后填写）
#   cp .env.example .env
# ------------------------------------------------------------
# ANTHROPIC_API_KEY 留空：后端以 mock 兜底，demo 仍可完整运行（不烧钱）
# 填入真实 key：analyzeUserMemory 等方法走真实 Claude
# ============================================================
ANTHROPIC_API_KEY=

# 模型分工（一般不用改）
LU_MODEL_SONNET=claude-sonnet-4-6
LU_MODEL_HAIKU=claude-haiku-4-5-20251001

# 服务端口
PORT=8000
