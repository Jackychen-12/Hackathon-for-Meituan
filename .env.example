# ============================================================
# 城脉 LU · 环境变量（复制为 .env 后填写）
#   cp .env.example .env
# ------------------------------------------------------------
# 路线规划 / 输入精炼 / 视觉识别 由 server.js 提供
# 至少配置一种可用的 LLM Key：
#   1) ARK_API_KEY
#   2) DEEPSEEK_API_KEY
#
# 都不配置时：
# - 首页和路线页仍可运行
# - /api/plan 会返回 fallback 默认路线
# - 前端会提示“未配置 AI Key”
# ============================================================

# ---------- 豆包 / ARK ----------
ARK_API_KEY=
ARK_API_URL=https://ark.cn-beijing.volces.com/api/v3/responses
ARK_MODEL=doubao-seed-1-6-vision-250815
ARK_API_URL_TEXT=https://ark.cn-beijing.volces.com/api/v3/chat/completions
ARK_TEXT_MODEL=doubao-seed-1-6-250615

# ---------- DeepSeek ----------
DEEPSEEK_API_KEY=

# ---------- 大众点评抓取（可选） ----------
DIANPING_COOKIE=

# ---------- 服务端口 ----------
# server.js 默认端口是 3000
PORT=3000
